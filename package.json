{
  "name": "wasmdb-root",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "frontend-packages/*",
    "examples/invoice-demo/frontend/apps/ui",
    "examples/invoice-demo/frontend/apps/wasm/pkg",
    "examples/invoice-demo/frontend/packages/generated",
    "examples/render-test/frontend/apps/ui",
    "examples/render-test/frontend/apps/wasm/pkg",
    "examples/render-test/frontend/packages/generated",
    "examples/render-test/tests",
    "examples/projection-demo/frontend/apps/ui",
    "examples/projection-demo/frontend/apps/wasm/pkg",
    "examples/projection-demo/frontend/packages/generated"
  ],
  "devDependencies": {
    "turbo": "^2"
  },
  "scripts": {
    "build:invoice": "turbo run build --filter=invoice-demo-ui",
    "dev:invoice": "turbo run dev --filter=invoice-demo-ui",
    "typecheck:invoice": "turbo run typecheck --filter=invoice-demo-ui",
    "build:render-test": "turbo run build --filter=render-test-ui",
    "dev:render-test": "turbo run dev --filter=render-test-ui",
    "typecheck:render-test": "turbo run typecheck --filter=render-test-ui",
    "test:render-test": "turbo run test:e2e --filter=render-test-tests",
    "build:projection-demo": "turbo run build --filter=projection-demo-ui",
    "dev:projection-demo": "turbo run dev --filter=projection-demo-ui",
    "typecheck:projection-demo": "turbo run typecheck --filter=projection-demo-ui"
  }
}
