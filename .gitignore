target/
node_modules/
.idea/
*.iml

# Vite build output (invoice-demo + render-test: frontend/apps/ui/dist).
examples/*/frontend/apps/*/dist/

# turbo cache
.turbo/
examples/*/frontend/.turbo/
examples/*/frontend/apps/*/.turbo/
examples/*/frontend/packages/*/.turbo/

# wasm-pack output: keep package.json (workspace anchor), ignore artifacts.
# wasm-pack also writes an inner pkg/.gitignore with `*` that takes precedence
# over this rule, so package.json is force-added to the index (`git add -f`)
# once. Subsequent rebuilds overwrite it with identical content (no diff).
# invoice-demo + render-test live at frontend/apps/wasm/pkg.
examples/*/frontend/apps/wasm/pkg/*
!examples/*/frontend/apps/wasm/pkg/package.json
